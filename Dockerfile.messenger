# Optional messenger worker (scaffold). Deploy when webhooks are implemented.
FROM node:22-alpine AS build

WORKDIR /app

COPY package.json package-lock.json ./
COPY apps/web/package.json ./apps/web/
COPY apps/messenger/package.json ./apps/messenger/
COPY packages/shared/package.json ./packages/shared/

RUN npm ci

COPY . .

RUN npm run build -w @apss/messenger

FROM node:22-alpine AS runtime

WORKDIR /app

ENV NODE_ENV=production

COPY package.json package-lock.json ./
COPY apps/web/package.json ./apps/web/
COPY apps/messenger/package.json ./apps/messenger/
COPY packages/shared/package.json ./packages/shared/

RUN npm ci --omit=dev

COPY --from=build /app/apps/messenger/dist ./apps/messenger/dist
COPY --from=build /app/packages/shared ./packages/shared

WORKDIR /app/apps/messenger

CMD ["node", "dist/index.js"]
