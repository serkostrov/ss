# --- apps/web ---
# Local (.env): used by Vite. Production (Dokploy): set the same names as runtime Environment.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_APP_URL=http://localhost:5173

# --- apps/messenger (runtime secrets, never in web image) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
MAX_BOT_TOKEN=
MAX_WEBHOOK_SECRET=
PUBLIC_WEBHOOK_BASE_URL=https://your-domain.example/webhooks
LOG_LEVEL=info
